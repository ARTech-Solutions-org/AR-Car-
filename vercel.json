{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/ar", "destination": "/ar/index.html" },
    { "source": "/ar/", "destination": "/ar/index.html" },
    { "source": "/photobooth", "destination": "/photobooth/index.html" },
    { "source": "/photobooth/", "destination": "/photobooth/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
