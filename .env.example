# ============================================================
# MG7 Photobooth + WebAR — Environment Configuration Template
# Copy this file to .env and fill in your actual API key and configuration
# ============================================================

# ── Gemini Imagen API Key ─────────────────────────────────────
GEMINI_API_KEY=YOUR_ACTUAL_API_KEY_HERE

# ── Gemini Models ─────────────────────────────────────────────
IMAGE_MODEL=imagen-4.0-fast-generate-001
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ── Server & Network Configuration ────────────────────────────
PORT=8080
AR_URL=http://YOUR_LAN_IP:8080/ar/index.html
